{
  "manifest_version": 3,
  "name": "Ambrosia",
  "version": "0.1.1",
  "description": "Personal scrapbook of the internet — archives videos, photos, and posts to your Sia storage.",
  "permissions": [
    "cookies",
    "contextMenus",
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://*.tiktok.com/*",
    "https://*.tiktokcdn.com/*",
    "https://*.tiktokcdn-us.com/*",
    "https://*.muscdn.com/*",
    "https://*.byteoversea.com/*",
    "https://*.ibyteimg.com/*",
    "https://*.instagram.com/*",
    "https://*.x.com/*",
    "https://*.twitter.com/*",
    "https://*.facebook.com/*",
    "https://*.fbcdn.net/*",
    "https://*.fbsbx.com/*",
    "https://*.reddit.com/*",
    "https://*.bsky.app/*",
    "https://*.vimeo.com/*",
    "https://*.twitch.tv/*",
    "https://ambrosia-web.fly.dev/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://ambrosia-web.fly.dev/*"],
      "js": ["content-bridge.js"],
      "run_at": "document_start"
    },
    {
      "matches": [
        "https://www.tiktok.com/@*/video/*",
        "https://www.tiktok.com/t/*",
        "https://vm.tiktok.com/*",
        "https://www.instagram.com/p/*",
        "https://www.instagram.com/reel/*",
        "https://www.instagram.com/tv/*",
        "https://x.com/*/status/*",
        "https://twitter.com/*/status/*",
        "https://www.facebook.com/share/*",
        "https://www.reddit.com/r/*/comments/*",
        "https://bsky.app/profile/*/post/*",
        "https://vimeo.com/*",
        "https://www.twitch.tv/*/clip/*",
        "https://clips.twitch.tv/*"
      ],
      "js": ["content-platform.js"],
      "css": ["content-platform.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Ambrosia"
  },
  "externally_connectable": {
    "matches": ["https://ambrosia-web.fly.dev/*"]
  }
}
